<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/theme.css" />
  </head>
  <body>
    <div id="analyzerApp">
      <header class="market-header">
        <div class="market-left">
          <span class="logo">PC CONFIG</span>
          <a href="/builder">Конфигуратор</a>
          <a href="/analyzer" class="active">Улучшение ПК</a>
        </div>
        <div class="market-right">
          <button class="ghost small" @click="logout">Выйти</button>
        </div>
      </header>

      <main class="dns-layout">
        <section class="catalog panel-light">
          <h1>Улучшение ПК</h1>
          <div class="row-head">
            <strong>Текущие комплектующие</strong>
            <span>{{ selectedCount }}/{{ categories.length }}</span>
          </div>
          <div class="config-row" v-for="category in categories" :key="category">
            <div class="row-name">
              <span class="icon">{{ categoryIcon[category] }}</span>
              <div>
                <div>{{ categoryLabels[category] }}</div>
                <small v-if="selectedItem(category)">{{ selectedItem(category).name }}</small>
              </div>
            </div>
            <div class="row-actions">
              <button class="small" @click="openPicker(category)">{{ selected[category] ? 'Изменить' : 'Выбрать' }}</button>
            </div>
          </div>
        </section>

        <aside class="summary panel-light">
          <h3>Аналитика</h3>
          <p class="muted">Выбрано {{ selectedCount }} компонентов</p>
          <div class="cart-box">
            <h4>Текущая корзина</h4>
            <div class="cart-item" v-for="item in cartItems" :key="item.id">
              <img class="picker-thumb" :src="itemThumb(item)" alt="component" />
              <div>
                <strong>{{ item.name }}</strong>
              </div>
            </div>
          </div>
          <button @click="analyze">Запустить анализ</button>
          <div class="service-box">
            <strong>Апгрейд-пакет</strong>
            <small class="muted">План улучшений + совместимость</small>
          </div>
        </aside>
      </main>

      <section class="saved panel-light" v-if="result">
        <h3>Результат анализа</h3>
        <p>Health score: <strong>{{ result.healthScore }}</strong></p>
        <ul class="saved-list">
          <li v-for="(item, idx) in result.suggestions" :key="idx">
            <strong>{{ item.category }}</strong>: {{ item.reason }} (+{{ item.estimatedImprovementPercent }}%)
          </li>
        </ul>
      </section>

      <div class="picker-backdrop" v-if="pickerOpen" @click.self="pickerOpen = false">
        <section class="picker-modal">
          <div class="picker-top">
            <h3>{{ categoryLabels[pickerCategory] }}</h3>
            <button class="ghost small" @click="pickerOpen = false">✕</button>
          </div>
          <input v-model.trim="pickerSearch" placeholder="Поиск по названию" />
          <div class="chips">
            <button class="chip-btn" :class="{ active: pickerTag === '' }" @click="pickerTag = ''">Все</button>
            <button class="chip-btn" v-for="tag in pickerFilters" :key="tag" :class="{ active: pickerTag === tag }" @click="pickerTag = tag">
              {{ tag }}
            </button>
          </div>
          <div class="picker-list">
            <article class="picker-item" v-for="item in pickerItems" :key="item.id">
              <img class="picker-thumb" :src="itemThumb(item)" alt="component" />
              <div>
                <strong>{{ item.name }}</strong>
                <p class="muted">Score {{ item.perf_score || 0 }}</p>
              </div>
              <div class="row-actions">
                <button class="ghost small" :class="{ active: isFavorite(item.id) }" @click="toggleFavorite(item.id)">Избранное</button>
                <button class="ghost small" :class="{ active: inCompare(item.id) }" @click="toggleCompare(item.id)">Сравнить</button>
                <button class="small" @click="pick(pickerCategory, item.id)">Выбрать</button>
              </div>
            </article>
          </div>
        </section>
      </div>
    </div>
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="/js/vue-analyzer.js"></script>
  </body>
</html>
